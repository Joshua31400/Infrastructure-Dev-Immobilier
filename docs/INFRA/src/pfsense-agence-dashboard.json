      "title": "Mémoire — Répartition",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_size_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "Totale",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_active_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "Active",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_wired_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "Wired (Kernel)",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_inactive_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "Inactive",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_memory_free_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "Libre",
          "refId": "E"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "ZFS ARC — Cache",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_zfs_arcstats_size_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "ARC Size",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_zfs_arcstats_c_max_bytes{job=\"pfsense-agence\"}",
          "legendFormat": "ARC Max",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "node_zfs_arcstats_c_bytes{job=\"pfsense-agence\"}",
