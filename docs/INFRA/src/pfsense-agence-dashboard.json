          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(node_network_transmit_drop_total{job=\"pfsense-agence\", device=~\"em0|em1|em1.20|em1.50\"}[5m])",
          "legendFormat": "TX Drop — {{device}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
